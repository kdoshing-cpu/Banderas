rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'displayName', 'flagsCount', 'totalTime', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.flagsCount is number && data.flagsCount >= 0 &&
             data.totalTime is number && data.totalTime >= 0 &&
             (!('timeAttackScore' in data) || (data.timeAttackScore is number && data.timeAttackScore >= 0)) &&
             data.updatedAt == request.time;
    }

    match /leaderboard/{userId} {
      allow get: if true;
      allow list: if true; // Public leaderboard
      allow create: if isOwner(userId) && isValidScore(request.resource.data);
      allow update: if isOwner(userId) && isValidScore(request.resource.data);
      allow delete: if isOwner(userId);
    }
  }
}
